{
  "templates": {
    "classic": {
      "name": "经典模板",
      "description": "传统简历格式，适合大多数行业",
      "suitable_for": ["通用", "金融", "政府"],
      "file": "classic.docx",
      "customizable": {
        "primary_color": {"type": "color", "default": "#1a1a1a", "label": "主色调"},
        "font_size": {"type": "select", "options": ["10", "11", "12"], "default": "11", "label": "正文字号"}
      }
    },
    "modern": {
      "name": "现代模板", 
      "description": "简洁现代设计，适合科技互联网",
      "suitable_for": ["科技", "互联网", "设计"],
      "file": "modern.docx",
      "customizable": {
        "accent_color": {"type": "color", "default": "#2563eb", "label": "强调色"},
        "font_size": {"type": "select", "options": ["10", "11", "12"], "default": "11", "label": "正文字号"}
      }
    },
    "simple": {
      "name": "简约模板",
      "description": "极简风格，内容为主",
      "suitable_for": ["教育", "科研", "医疗"],
      "file": "simple.docx",
      "customizable": {
        "primary_color": {"type": "color", "default": "#374151", "label": "主色调"}
      }
    },
    "creative": {
      "name": "创意模板",
      "description": "独特设计，展现个性",
      "suitable_for": ["广告", "媒体", "艺术"],
      "file": "creative.docx",
      "customizable": {
        "gradient_start": {"type": "color", "default": "#667eea", "label": "渐变起始色"},
        "gradient_end": {"type": "color", "default": "#764ba2", "label": "渐变结束色"}
      }
    },
    "professional": {
      "name": "专业模板",
      "description": "商务专业风格",
      "suitable_for": ["管理", "咨询", "法律"],
      "file": "professional.docx",
      "customizable": {
        "primary_color": {"type": "color", "default": "#0f172a", "label": "主色调"},
        "border_style": {"type": "select", "options": ["solid", "double", "none"], "default": "solid", "label": "分隔线样式"}
      }
    }
  },
  "default_template": "classic"
}